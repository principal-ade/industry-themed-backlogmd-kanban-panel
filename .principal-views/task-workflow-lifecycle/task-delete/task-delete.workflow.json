{
  "version": "1.0.0",
  "canvas": ".principal-views/task-workflow-lifecycle/task-workflow-lifecycle.otel.canvas",
  "name": "Task Delete",
  "description": "Deleting a task via context menu",
  "spanPattern": "task.delete",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "success",
      "priority": 1,
      "description": "Task deleted successfully",
      "template": {
        "events": {
          "delete.modal.opened": "Opened delete confirmation for {{task.id}}",
          "task.deleted": "Deleted task {{task.id}}",
          "kanban.loaded": "Board refreshed ({{tasks.count}} tasks in {{columns.count}} columns, has more: {{has.more}})"
        },
        "summary": "Task deleted: {{task.id}}"
      }
    },
    {
      "id": "error",
      "priority": 2,
      "description": "Failed to delete task",
      "template": {
        "events": {
          "delete.modal.opened": "Opened delete confirmation for {{task.id}}",
          "task.deleted": "Attempted to delete {{task.id}}",
          "task.save.error": "{{operation}} failed for {{task.id}}: {{error.type}} - {{error.message}}"
        },
        "summary": "Delete failed: {{error.type}}"
      }
    }
  ]
}
