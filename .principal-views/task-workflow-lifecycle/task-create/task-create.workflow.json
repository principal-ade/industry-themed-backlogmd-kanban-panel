{
  "version": "1.0.0",
  "canvas": ".principal-views/task-workflow-lifecycle/task-workflow-lifecycle.otel.canvas",
  "name": "Task Create",
  "description": "Creating a new task via the task modal",
  "spanPattern": "task.create",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "success",
      "priority": 1,
      "description": "Task created successfully",
      "template": {
        "events": {
          "modal.opened": "{{modal.mode}} modal opened{{#task.id}} for {{task.id}}{{/task.id}}",
          "task.created": "Created task {{task.id}} in {{task.status}} ({{file.path}})",
          "kanban.loaded": "Board refreshed ({{tasks.count}} tasks in {{columns.count}} columns, has more: {{has.more}})"
        },
        "summary": "Task created: {{task.id}}"
      }
    },
    {
      "id": "error",
      "priority": 2,
      "description": "Failed to create task",
      "template": {
        "events": {
          "modal.opened": "{{modal.mode}} modal opened{{#task.id}} for {{task.id}}{{/task.id}}",
          "task.created": "Attempted to create task",
          "task.save.error": "{{operation}} failed for {{task.id}}: {{error.type}} - {{error.message}}"
        },
        "summary": "Create failed: {{error.type}}"
      }
    },
    {
      "id": "cancelled-with-changes",
      "priority": 3,
      "description": "User cancelled task creation with unsaved changes",
      "template": {
        "events": {
          "modal.opened": "{{modal.mode}} modal opened{{#task.id}} for {{task.id}}{{/task.id}}",
          "modal.cancelled": "{{modal.mode}} cancelled (had changes: {{had.changes}})"
        },
        "summary": "Create cancelled"
      }
    },
    {
      "id": "cancelled",
      "priority": 4,
      "description": "User cancelled task creation",
      "template": {
        "events": {
          "modal.opened": "{{modal.mode}} modal opened{{#task.id}} for {{task.id}}{{/task.id}}",
          "modal.cancelled": "{{modal.mode}} cancelled (had changes: {{had.changes}})"
        },
        "summary": "Create cancelled"
      }
    }
  ]
}
