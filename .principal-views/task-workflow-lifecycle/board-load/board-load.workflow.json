{
  "version": "1.0.0",
  "canvas": ".principal-views/task-workflow-lifecycle/task-workflow-lifecycle.otel.canvas",
  "name": "Board Load",
  "description": "Kanban board initialization and task loading",
  "spanPattern": "kanban.load",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "backlog-success-with-tasks",
      "priority": 1,
      "description": "Backlog board initialized and tasks loaded",
      "template": {
        "events": {
          "kanban.loading": "Loading backlog (is backlog: {{is.backlog.project}})",
          "kanban.loaded": "Loaded {{tasks.count}} tasks in {{columns.count}} columns (has more: {{has.more}})"
        },
        "summary": "Board loaded: {{tasks.count}} tasks"
      }
    },
    {
      "id": "backlog-success-empty",
      "priority": 2,
      "description": "Backlog board initialized with no tasks",
      "template": {
        "events": {
          "kanban.loading": "Loading backlog (is backlog: {{is.backlog.project}})",
          "kanban.loaded": "No tasks found (has more: {{has.more}})"
        },
        "summary": "Empty board"
      }
    },
    {
      "id": "error",
      "priority": 3,
      "description": "Board failed to load",
      "template": {
        "events": {
          "kanban.loading": "Loading tasks... (is backlog: {{is.backlog.project}})",
          "kanban.load.error": "Load failed: {{error.type}} - {{error.message}}"
        },
        "summary": "Load error: {{error.type}}"
      }
    }
  ]
}
