{
  "version": "1.0.0",
  "canvas": ".principal-views/task-workflow-lifecycle/task-workflow-lifecycle.otel.canvas",
  "name": "Board Interactions",
  "description": "Board interactions - task selection, pagination, filter, search, empty state",
  "spanPattern": "board.interaction",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "task-selected-with-status",
      "priority": 1,
      "description": "Task selected for viewing (with status)",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}} ({{task.status}})",
          "task.selected.emitted": "Emitted {{task.id}} to TaskDetailPanel"
        },
        "summary": "Viewing: {{task.id}}"
      }
    },
    {
      "id": "task-selected",
      "priority": 2,
      "description": "Task selected for viewing",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}}",
          "task.selected.emitted": "Emitted {{task.id}} to TaskDetailPanel"
        },
        "summary": "Viewing: {{task.id}}"
      }
    },
    {
      "id": "load-more",
      "priority": 3,
      "description": "User loaded more tasks (pagination)",
      "template": {
        "events": {
          "kanban.load.more": "Loading more tasks (offset: {{offset}}, limit: {{limit}})",
          "kanban.loaded": "Now showing {{tasks.count}} tasks across {{columns.count}} columns (has more: {{has.more}})"
        },
        "summary": "Loaded more tasks"
      }
    },
    {
      "id": "column-selected",
      "priority": 4,
      "description": "User switched to different status tab",
      "template": {
        "events": {
          "column.selected": "Switched to {{column.status}} (from {{column.previous}})"
        },
        "summary": "Viewing: {{column.status}}"
      }
    },
    {
      "id": "filter-cleared",
      "priority": 5,
      "description": "User cleared filters",
      "template": {
        "events": {
          "filter.cleared": "Cleared {{filters.count}} filters"
        },
        "summary": "Filters cleared"
      }
    },
    {
      "id": "search",
      "priority": 6,
      "description": "User searched for tasks",
      "template": {
        "events": {
          "search.performed": "Searched for \"{{search.query}}\" - {{results.count}} results"
        },
        "summary": "Search: {{results.count}} results"
      }
    },
    {
      "id": "create-task-clicked",
      "priority": 7,
      "description": "User clicked add task button",
      "template": {
        "events": {
          "create.task.clicked": "Add task clicked (source: {{source}})"
        },
        "summary": "Create task from {{source}}"
      }
    },
    {
      "id": "task-deselected",
      "priority": 8,
      "description": "User closed the task detail panel",
      "template": {
        "events": {
          "task.deselected": "Closed task {{task.id}}"
        },
        "summary": "Task closed"
      }
    }
  ]
}
