{
  "version": "1.0.0",
  "canvas": ".principal-views/task-workflow-lifecycle/task-workflow-lifecycle.otel.canvas",
  "name": "Task Edit",
  "description": "Editing a task via the task modal or drag-and-drop",
  "spanPattern": "task.edit",
  "mode": "span-tree",
  "scenarios": [
    {
      "id": "drag-completed",
      "priority": 1,
      "description": "Task dragged and dropped successfully",
      "template": {
        "events": {
          "task.drag.started": "Started dragging {{task.id}} from {{from.status}}",
          "task.moved": "{{task.id}} moved from {{from.status}} to {{to.status}}",
          "task.updated": "Status persisted for {{task.id}}"
        },
        "summary": "Moved: {{from.status}} to {{to.status}}"
      }
    },
    {
      "id": "drag-cancelled",
      "priority": 2,
      "description": "Drag operation cancelled",
      "template": {
        "events": {
          "task.drag.started": "Started dragging {{task.id}} from {{from.status}}",
          "task.drag.cancelled": "Drag cancelled for {{task.id}} (was in {{from.status}})"
        },
        "summary": "Drag cancelled"
      }
    },
    {
      "id": "modal-success-with-fields",
      "priority": 3,
      "description": "Task edited successfully via modal with field details",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}} ({{task.status}})",
          "modal.opened": "{{modal.mode}} modal opened for {{task.id}}",
          "task.updated": "Updated {{task.id}} ({{updated.fields}})",
          "kanban.loaded": "Board refreshed ({{tasks.count}} tasks in {{columns.count}} columns, has more: {{has.more}})"
        },
        "summary": "Task edited: {{task.id}}"
      }
    },
    {
      "id": "modal-success",
      "priority": 4,
      "description": "Task edited successfully via modal",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}} ({{task.status}})",
          "modal.opened": "{{modal.mode}} modal opened for {{task.id}}",
          "task.updated": "Updated {{task.id}}",
          "kanban.loaded": "Board refreshed ({{tasks.count}} tasks in {{columns.count}} columns, has more: {{has.more}})"
        },
        "summary": "Task edited: {{task.id}}"
      }
    },
    {
      "id": "modal-error",
      "priority": 5,
      "description": "Failed to save task edits via modal",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}} ({{task.status}})",
          "modal.opened": "{{modal.mode}} modal opened",
          "task.updated": "Attempted to update {{task.id}}",
          "task.save.error": "{{operation}} failed for {{task.id}}: {{error.type}} - {{error.message}}"
        },
        "summary": "Edit failed: {{error.type}}"
      }
    },
    {
      "id": "modal-cancelled-with-changes",
      "priority": 6,
      "description": "User cancelled task edit via modal with unsaved changes",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}} ({{task.status}})",
          "modal.opened": "{{modal.mode}} modal opened",
          "modal.cancelled": "{{modal.mode}} cancelled (had changes: {{had.changes}})"
        },
        "summary": "Edit cancelled"
      }
    },
    {
      "id": "modal-cancelled",
      "priority": 7,
      "description": "User cancelled task edit via modal",
      "template": {
        "events": {
          "task.selected": "Selected task {{task.id}} ({{task.status}})",
          "modal.opened": "{{modal.mode}} modal opened",
          "modal.cancelled": "{{modal.mode}} cancelled (had changes: {{had.changes}})"
        },
        "summary": "Edit cancelled"
      }
    }
  ]
}
